font-family = "VictorMono NF Medium"
font-family-bold = "VictorMono NF"
font-family-italic = "VictorMono NF"
font-family-bold-italic = "VictorMono NF"
font-style-bold = "Bold"
font-style-italic = "Medium Oblique"
font-style-bold-italic = "Bold Oblique"
font-size = 15
adjust-cell-height = -4
adjust-cursor-thickness = 1
adjust-cursor-height = -4

theme = "iTerm2 Tango Dark"
mouse-hide-while-typing = true
unfocused-split-fill = "#000000"
cursor-style = "block"
cursor-style-blink = false
cursor-invert-fg-bg = true
shell-integration-features = "no-cursor"

window-padding-balance = true
window-padding-color = "extend"
gtk-titlebar = false
gtk-tabs-location = "bottom"
click-repeat-interval = 300
link-url = false

keybind = clear
keybind = ctrl+alt+h=goto_split:left
keybind = ctrl+alt+j=goto_split:bottom
keybind = ctrl+alt+k=goto_split:top
keybind = ctrl+alt+l=goto_split:right
keybind = ctrl+alt+shift+h=resize_split:left,10
keybind = ctrl+alt+shift+j=resize_split:down,10
keybind = ctrl+alt+shift+k=resize_split:up,10
keybind = ctrl+alt+shift+l=resize_split:right,10
keybind = ctrl+alt+shift+semicolon=equalize_splits
keybind = ctrl+alt+m=toggle_split_zoom
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = shift+insert=paste_from_selection
keybind = ctrl+shift+a=select_all
keybind = ctrl+shift+plus=increase_font_size:0.5
keybind = ctrl+shift+minus=decrease_font_size:0.5
keybind = ctrl+shift+zero=reset_font_size
keybind = ctrl+alt+e=new_tab
keybind = ctrl+alt+left_bracket=previous_tab
keybind = ctrl+alt+right_bracket=next_tab
keybind = ctrl+alt+shift+tab=previous_tab
keybind = ctrl+alt+tab=next_tab
keybind = ctrl+shift+left_bracket=move_tab:-1
keybind = ctrl+shift+right_bracket=move_tab:1
keybind = ctrl+alt+o=toggle_tab_overview
keybind = ctrl+alt+enter=new_split:auto
keybind = ctrl+alt+n=new_window
keybind = ctrl+alt+w=close_surface
keybind = ctrl+alt+slash=write_scrollback_file:open
keybind = ctrl+alt+g>k=scroll_to_top
keybind = ctrl+alt+g>j=scroll_to_bottom
keybind = ctrl+alt+d=scroll_page_fractional:0.5
keybind = ctrl+alt+u=scroll_page_fractional:-0.5
keybind = ctrl+alt+f=scroll_page_down
keybind = ctrl+alt+b=scroll_page_up
keybind = ctrl+alt+comma=jump_to_prompt:-1
keybind = ctrl+alt+period=jump_to_prompt:1
keybind = ctrl+shift+comma=open_config
keybind = ctrl+shift+period=reload_config
